# Copy to .env and fill in. All variables are prefixed ARGUS_.

# All Parquet + DuckDB files live here. MUST be outside any OneDrive-synced tree;
# startup refuses a synced path unless ARGUS_ALLOW_SYNCED_DATA_ROOT=1.
ARGUS_DATA_ROOT=C:\argus-data

# Alpaca free account (IEX feed) - needed for quote capture (j05). Blank = job skips.
ARGUS_ALPACA_KEY_ID=
ARGUS_ALPACA_SECRET_KEY=

# Polygon free tier (5 calls/min) - needed from M1 (corporate actions drip). Blank = job skips.
ARGUS_POLYGON_API_KEY=

# SEC EDGAR fair-access policy requires a descriptive User-Agent with contact info.
ARGUS_EDGAR_USER_AGENT=ARGUS research (you@example.com)
