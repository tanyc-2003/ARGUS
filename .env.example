# Copy to .env and fill in. All variables are prefixed ARGUS_.

# All Parquet + DuckDB files live here (plus the venv, if you use setup_argus.bat).
# MUST be outside any OneDrive-synced tree; startup refuses a synced path unless
# ARGUS_ALLOW_SYNCED_DATA_ROOT=1. Any local disk works — scripts\setup_argus.bat
# prompts for one and rewrites just this line, leaving the keys below untouched.
ARGUS_DATA_ROOT=C:\argus-data

# Optional: per-source nightly call budgets (ceilings, not targets). Defaults live
# in settings.py and are sized against the universe/watchlist — see docs/reliability.md.
# Setting one here OVERRIDES the default permanently, including after an upgrade
# that raises it, so leave them commented unless you mean it.
#ARGUS_POLYGON_NIGHTLY_BUDGET=400
#ARGUS_YFINANCE_NIGHTLY_BUDGET=600
#ARGUS_ALPACA_NIGHTLY_BUDGET=15000

# Alpaca free account (IEX feed) - needed for quote capture (j05). Blank = job skips.
ARGUS_ALPACA_KEY_ID=
ARGUS_ALPACA_SECRET_KEY=

# Polygon free tier (5 calls/min) - needed from M1 (corporate actions drip). Blank = job skips.
ARGUS_POLYGON_API_KEY=

# SEC EDGAR fair-access policy requires a descriptive User-Agent with contact info.
ARGUS_EDGAR_USER_AGENT=ARGUS research (you@example.com)
